{
  "name": "arc-todo-api",
  "version": "0.1.0",
  "description": "Arc Todo API",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:prod:migrate": "npm run migration:run && npm run start:prod",
    "typeorm": "typeorm-ts-node-commonjs -d src/data-source.ts",
    "migration:generate": "npm run build && typeorm migration:generate",
    "migration:run": "typeorm migration:run -d dist/data-source.js",
    "migration:revert": "typeorm migration:revert -d dist/data-source.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test:scope": "npm run build && node dist/scope-resolver/scope-match.util.js",
    "test:task-history": "npm run build && node dist/tasks/task-history.util.js",
    "test:task-metadata": "npm run build && node dist/tasks/task-metadata.util.js",
    "test:task-hierarchy": "npm run build && node dist/tasks/task-hierarchy.util.js",
    "test:board-cycle": "npm run build && node dist/board-cycles/board-cycle.util.js",
    "test:acronym": "npm run build && node dist/common/utils/acronym.util.js",
    "test:rag-cleanup": "npm run build && node dist/rag-settings/rag-cleanup.util.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "minio": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "typescript": "^5.7.0"
  }
}
